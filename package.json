{
  "name": "spacex-launch-gap-calendar",
  "version": "1.0.0",
  "description": "A simple aggregated view of all SpaceX launches on a calendar. Shows days that haven't had a launch as well as reference to which launches happened on that day",
  "type": "module",
  "scripts": {
    "fetch-launches": "node scripts/fetchLaunches.js",
    "fetch-launches:full": "node scripts/fetchLaunches.js --full-refetch",
    "screenshot": "node scripts/screenshot.js",
    "generate-og": "node scripts/generateOgImage.js",
    "dev": "npx serve .",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "playwright": "^1.49.0"
  },
